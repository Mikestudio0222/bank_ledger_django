# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# CSRF trusted origins for HTTPS (comma-separated)
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Database Settings
# Use sqlite for local development or mysql for MySQL.
DB_ENGINE=mysql
SQLITE_NAME=db.sqlite3

# MySQL Database Settings (used when DB_ENGINE=mysql)
DB_NAME=bank_ledger
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# Email Settings (SMTP)
# For Gmail: smtp.gmail.com, port 587, TLS=True
# For QQ mail: smtp.qq.com, port 587, TLS=True
# For development: use django.core.mail.backends.console.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
